  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level1_AfterJetpack
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u786E\u5B9E\u5F88\u65B9\u4FBF\uFF0C\u5C31\u662F\u8FD8\u5F97\u82B1\u65F6\u95F4\u9002\u5E94\u2026\u2026\u5B83\u80FD\u652F\u6301\u6211\u4EEC\u884C\u52A8\u591A\u4E45\u5462\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u5728\u7EC8\u7AEF\u754C\u9762\u4E0B\u6DFB\u52A0\u4E86\u80FD\u91CF\u6761\uFF0C\u65B9\u4FBF\u968F\u65F6\u68C0\u67E5\u5269\u4F59\u71C3\u6599\u91CF\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u4E5F\u7B97\u662F\u8D70\u4E86\u300C\u72D7\u5C4E\u8FD0\u300D\u5427\uFF0C\u9668\u77F3\u4E5F\u7834\u574F\u4E86\u5E9F\u5F03\u7A7A\u95F4\u7AD9\u3002\u8FD9\u9644\u8FD1\u4E5F\u6F02\u6D6E\u7740\u5F88\u591A\u6CC4\u9732\u7684\u80FD\u91CF\uFF0C\u53EA\u8981\u9760\u8FD1\u5B83\u4EEC\uFF0C\u80CC\u5305\u7684\u80FD\u91CF\u5C31\u4F1A\u88AB\u8865\u5145\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u65B9\u6CE2"
    text: "\u539F\u6765\u5982\u6B64\uFF0C\u4E0D\u8FC7\u5173\u4E8E\u72D7\u7684\u53CC\u5173\u4E0D\u597D\u7B11\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u4F60\u660E\u660E\u633A\u559C\u6B22\u7684\u5427\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u987A\u4FBF\uFF0C\u5C31\u50CF\u4F60\u8BF4\u7684\uFF0C\u8FD9\u91CC\u7684\u91CD\u529B\u73AF\u5883\u5F88\u7279\u522B\uFF0C\u548C\u6BCD\u661F\u4E0D\u592A\u4E00\u6837\u3002\u4E00\u5B9A\u8981\u6293\u597D\u5F39\u529B\u7EF3\u3002\u5426\u5219\u6211\u62C5\u5FC3\u81EA\u5DF1\u88AB\u4F60\u7529\u98DE\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u65B9\u6CE2"
    text: "\u6211\u529B\u6C14\u54EA\u91CC\u6709\u90A3\u4E48\u5927\uFF01\u4E0D\u8FC7\uFF0C\u4F60\u770B\u90A3\u8FB9\u7684\u5899\u9762\uFF0C\u6709\u5199\u7740\u8FD9\u91CC\u7684\u5DE5\u4F5C\u6307\u5357\u3002\u4F3C\u4E4E\u53EA\u8981\u6309\u4F4F\u8FD9\u4E2A\u952E\u5C31\u53EF\u4EE5\u5438\u9644\u5728\u9644\u8FD1\u7684\u5730\u5757\u4E0A\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: 
    text: "\u8BD5\u7740\u6309\u4F4F\u3010Left Shift / Enter\u3011\u5438\u9644\u5230\u5730\u9762\u5427\uFF01\u60F3\u8981\u8131\u79BB\u5730\u9762\uFF0C\u518D\u6309\u4E00\u6B21\u5373\u53EF\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u5FD8\u8BB0\u64CD\u4F5C\u7684\u65F6\u5019\uFF0C\u53EF\u4EE5\u770B\u4E00\u4E0B\u4EBA\u7C7B\u7559\u4E0B\u6765\u7684\u5DE5\u4F5C\u6307\u5357\u54E6\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 0
  onComplete:
    m_PersistentCalls:
      m_Calls: []
