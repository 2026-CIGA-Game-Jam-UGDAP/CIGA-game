  lines:
  - speakerName: 
    text: "\u5F53\u4F60\u610F\u8BC6\u5230\u81EA\u5DF1\u4E0D\u5E94\u8BE5\u98DE\u51FA\u8FD9\u4E48\u8FDC\u7684\u65F6\u5019\uFF0C\u4E00\u5207\u90FD\u665A\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
  - speakerName: 
    text: "\u98D8\u5728\u592A\u7A7A\u4E2D\u786E\u5B9E\u8BA9\u4F60\u60F3\u5230\u5F88\u591A\u4E8B\u60C5\uFF1A42\u3001\u81F4\u8FDC\u661F\u7684\u6218\u51B5\u3001\u8FD8\u6709\u5E94\u8BE5\u63D0\u524D\u770B\u9668\u77F3\u96E8\u7684\u9884\u62A5\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
  - speakerName: 
    text: "\u65E0\u8BBA\u5982\u4F55\uFF0C\u4F60\u4EEC\u786E\u5B9E\u98D8\u7684\u8D8A\u6765\u8D8A\u8FDC\u4E86\u3002\"\u65B9\u6CE2\u548C\u62C9\u5179\uFF0C\u6211\u4EEC\u6709\u9EBB\u70E6\u4E86\u3002\""
