  m_Name: Level1_Enter
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u8FD9\u8239\u72B6\u6001\u4E0D\u9519\uFF0C\u6CA1\u6709\u5F88\u4E25\u91CD\u7684\u635F\u574F\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u4EBA\u7C7B\u8FD8\u662F\u7559\u4E0B\u4E86\u4E0D\u5C11\u6709\u7528\u7684\u96F6\u4EF6\u7684\u3002\u53EA\u8981\u6536\u96C6\u5230\u8FD9\u4E9B\u4E1C\u897F\uFF0C\u8FD9\u8258\u98DE\u8239\u5E94\u8BE5\u5C31\u8FD8\u80FD\u4FEE\u3002\u6E05\u5355\u540C\u6B65\u7ED9\u4F60\u4E86\uFF0C\u4F60\u5E94\u8BE5\u80FD\u770B\u5230\uFF0C\u5728\u7EC8\u7AEF\u7684\u53F3\u4E0A\u89D2\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u4EEC\u63A5\u4E0B\u6765\u8981\u53BB\u884C\u661F\u4E2D\u6536\u96C6\u8FD9\u4E9B\u96F6\u4EF6\u5BF9\u5427\uFF1F\u542C\u7740\u771F\u523A\u6FC0\uFF01\u4F60\u8BF4\u7B49\u6211\u4EEC\u56DE\u53BB\u4E86\uFF0C\u662F\u4E0D\u662F\u4E5F\u53EF\u4EE5\u8BD5\u7740\u5F00\u53D1\u4E00\u4E2A\u76F8\u5173\u7684\u4E3B\u9898\u4E50\u56ED\u2026\u2026\u5C31\u53EB\"\u73AF\u7403\u5EFA\u6210\"\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u597D\u5566\uFF0C\u7B49\u6211\u4EEC\u56DE\u53BB\u518D\u7422\u78E8\u3002\u5148\u5F00\u59CB\u6536\u96C6\u96F6\u4EF6\u5427\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 0
