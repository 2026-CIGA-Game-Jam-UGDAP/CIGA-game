  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level1_Enter
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u6211\u7684\u8001\u5B87\u5B99\u554A\u2026\u2026\u98DE\u8239\u574F\u6210\u8FD9\u6837\uFF0C\u522B\u8BF4\u63A2\u9669\u4E86\uFF0C\u8FDE\u6BCD\u661F\u90FD\u56DE\u4E0D\u53BB\u4E86\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 1
  - speakerName: "\u65B9\u6CE2"
    text: "\u5F97\u60F3\u60F3\u529E\u6CD5\uFF0C\u8981\u4E0D\u7136\u2026\u2026\u55EF\uFF1F\u62C9\u5179\uFF0C\u4F60\u5728\u505A\u4EC0\u4E48\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u521A\u521A\u626B\u63CF\u4E86\u4E00\u4E0B\u9644\u8FD1\u7684\u73AF\u5883\u3002\u4EBA\u7C7B\u8FD8\u662F\u7559\u4E0B\u4E86\u4E0D\u5C11\u6709\u7528\u7684\u96F6\u4EF6\u7684\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u53EA\u8981\u6536\u96C6\u5230\u8FD9\u4E9B\u4E1C\u897F\uFF0C\u6211\u5C31\u6709\u4FE1\u5FC3\u4FEE\u597D\u6211\u4EEC\u7684\u98DE\u8239\u3002\u6E05\u5355\u540C\u6B65\u7ED9\u4F60\u4E86\uFF0C\u4F60\u5E94\u8BE5\u80FD\u770B\u5230\uFF0C\u5728\u7EC8\u7AEF\u7684\u53F3\u4E0A\u89D2\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: "\u65B9\u6CE2"
    text: "\u4E0D\u8FC7\u5B83\u4EEC\u5B8C\u5168\u6563\u5728\u56DB\u5468\uFF0C\u8FD9\u91CC\u91CD\u529B\u8FD9\u4E48\u4E0D\u7A33\u5B9A\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u54FC\u54FC\uFF0C\u8FD8\u662F\u6709\u6CD5\u5B50\u7684\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u521A\u521A\u53D1\u73B0\u4E86\u5F88\u6709\u8DA3\u7684\u4E1C\u897F\u2026\u2026\u6765\uFF0C\u4F60\u5148\u628A\u8FD9\u4E2A\u88C5\u4E0A\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u8FD9\u662F\u4EBA\u7C7B\u7559\u4E0B\u7684\u55B7\u6C14\u80CC\u5305\uFF0C\u8D77\u7801\u6709\u4E86\u8FD9\u4E2A\u6211\u4EEC\u884C\u52A8\u8D77\u6765\u5C31\u65B9\u4FBF\u591A\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: 
    text: "\u8BD5\u7740\u6309\u52A8\u3010WASD / \u65B9\u5411\u952E\u3011\u542F\u52A8\u55B7\u6C14\u80CC\u5305\u5427\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  useTypingEffect: 1
  useAnimation: 1
  needsCG: 0
  onComplete:
    m_PersistentCalls:
      m_Calls: []
