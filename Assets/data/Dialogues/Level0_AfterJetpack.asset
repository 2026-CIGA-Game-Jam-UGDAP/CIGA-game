  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level0_AfterJetpack
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u4EBA\u7C7B\u8FD8\u53D1\u660E\u8FC7\u8FD9\u4E48\u65B9\u4FBF\u7684\u4E1C\u897F\uFF1F\u6211\u8FD8\u4EE5\u4E3A\u4ED6\u4EEC\u7B28\u5230\u53EA\u80FD\u5F80\u5B87\u5B99\u91CC\u6254\u8FDD\u7AE0\u5EFA\u7B51\u5462\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u60F3\u8FD9\u662F\u4ED6\u4EEC\u5728\u5B87\u5B99\u91CC\u79FB\u52A8\u7684\u4E3B\u8981\u624B\u6BB5\uFF0C\u6BD5\u7ADF\u4ED6\u4EEC\u8EAB\u5B50\u592A\u4E0D\u8F7B\u5DE7\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u4E0D\u8FC7\u867D\u7136\u662F\u5168\u65B0\u7684\uFF0C\u4E5F\u4E0D\u77E5\u9053\u5B83\u80FD\u652F\u6491\u591A\u4E45\u5462\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u5728\u7EC8\u7AEF\u754C\u9762\u4E0B\u6DFB\u52A0\u4E86\u80FD\u91CF\u6761\uFF0C\u65B9\u4FBF\u968F\u65F6\u68C0\u67E5\u5269\u4F59\u71C3\u6599\u3002\u521A\u521A\u6211\u4EEC\u7684\u8BD5\u98DE\u5DF2\u7ECF\u9020\u6210\u71C3\u6599\u7684\u635F\u8017\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u8D77\u7801\u8FD9\u6837\u4E0D\u4F1A\u51FA\u73B0\u5F00\u4E00\u534A\u6CA1\u6CB9\u7684\u60C5\u51B5\u2026\u2026\u4F46\u4E5F\u5F97\u5BFB\u627E\u8865\u5145\u80FD\u91CF\u7684\u65B9\u6CD5\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u5F80\u524D\u597D\u50CF\u6709\u51FA\u53E3\uFF0C\u6211\u4EEC\u5148\u98DE\u51FA\u53BB\u770B\u770B\u5427\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 0
  onComplete:
    m_PersistentCalls:
      m_Calls: []
