  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u80FD\u91CF\u6761\u786E\u5B9E\u6062\u590D\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u597D\u4E8B\u4E00\u6869\u63A5\u4E00\u6869\uFF0C\u4F60\u770B\u524D\u9762\u90A3\u4E2A\u9EC4\u8272\u7684\u2014\u2014"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u2014\u2014\u4E00\u8258\u5E9F\u5F03\u7684\u98DE\u8239\uFF1F\uFF01\u800C\u4E14\u521A\u597D\u53EF\u4EE5\u8F7D\u4EBA\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u5468\u56F4\u73AF\u5883\u626B\u63CF\u5B8C\u6BD5\u3002\u8FD9\u9644\u8FD1\u7684\u51E0\u4E2A\u5C0F\u884C\u661F\u628A\u5E9F\u5F03\u7A7A\u95F4\u7AD9\u7684\u4E00\u4E9B\u96F6\u4EF6\u7EB3\u5165\u4E86\u5B83\u4EEC\u7684\u8F68\u9053\uFF0C\u6211\u4EEC\u53EF\u4EE5\u901A\u8FC7\u6536\u96C6\u8FD9\u4E9B\u96F6\u4EF6\u6765\u4FEE\u7F2E\u8FD9\u5EA7\u98DE\u8239\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u4F46\u9996\u5148\uFF0C\u6211\u4EEC\u8981\u5148\u8FC7\u53BB\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: 
    text: "\u5C1D\u8BD5\u501F\u52A9\u5438\u9644\u3001\u89E3\u9664\u5438\u9644\u548C\u80CC\u5305\u7684\u5E2E\u52A9\u5230\u8FBE\u98DE\u8239\u5427\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
  useTypingEffect: 1
  useAnimation: 0
