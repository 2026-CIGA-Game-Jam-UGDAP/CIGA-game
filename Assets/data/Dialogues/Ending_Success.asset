  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Ending_Success
  m_EditorClassIdentifier: 
  lines:
  - speakerName: 
    text: "\u63D0\u793A\u7528\u6295\u5F71\u4EAE\u8D77\uFF0C\u9EC4\u8272\u7684\u98DE\u8239\u7EC8\u4E8E\u5F97\u4EE5\u53D1\u52A8\u3002\u4E24\u4F4D\u63A2\u9669\u5BB6\u5750\u4E0A\u9A7E\u9A76\u8231\uFF0C\u9003\u79BB\u8EAB\u540E\u7684\u9668\u77F3\u96E8\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u56DB\u9762\u516B\u65B9\u6D8C\u6765\u7684\u5F57\u661F\u4E0E\u884C\u661F\u788E\u7247\u649E\u51FB\u7740\u4EBA\u7C7B\u6587\u660E\u5728\u592A\u9633\u7CFB\u7684\u6700\u540E\u4E00\u70B9\u6B8B\u7559\uFF0C\u5728\u9644\u8FD1\u7684\u5C0F\u884C\u661F\u8EAB\u4E0A\u7559\u4E0B\u5927\u5927\u5C0F\u5C0F\u7684\u9668\u77F3\u5751\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u98DE\u8239\u7684\u5C3E\u7130\u7529\u51FA\u53CD\u65B9\u5411\uFF0C\u8FD9\u8258\u642D\u8F7D\u7740\u4EBA\u7C7B\u667A\u6167\u7684\u5916\u661F\u822A\u8239\uFF0C\u4F1A\u4E00\u8DEF\u9A76\u51FA\u94F6\u6CB3\u7CFB\u3001\u4E00\u5934\u683D\u8FDB\u65E0\u540D\u7684\u661F\u4E91\uFF0C\u76F4\u5230\u56DE\u5230\u63A2\u9669\u5BB6\u6E29\u99A8\u7684\u6BCD\u661F\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u76F4\u5230\u628A\u4EBA\u7C7B\u6587\u660E\u5E26\u5230\u4EBA\u7C7B\u90FD\u672A\u66FE\u63A2\u7D22\u8FC7\u7684\u5730\u65B9\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 0
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 1
  onComplete:
    m_PersistentCalls:
      m_Calls: []
