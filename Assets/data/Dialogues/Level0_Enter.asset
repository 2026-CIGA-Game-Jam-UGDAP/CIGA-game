  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level0_Enter
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u8FD9\u91CC\u662F\u2026\u2026\u88AB\u7838\u5F00\u7684\u4EBA\u7C7B\u7A7A\u95F4\u7AD9\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u62C9\u5179\uFF0C\u6211\u4EEC\u7684\u98DE\u8239\u662F\u4E0D\u662F\u2026\u2026\u5F7B\u5E95\u88AB\u9668\u661F\u649E\u788E\u6210\u6E23\u4E86\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u55EF\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u8FD8\u6709\u4EC0\u4E48\u8865\u6551\u7684\u673A\u4F1A\u5427\uFF1F\u6BD4\u5982\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u65B9\u6CE2\uFF0C\u6211\u53EF\u4EE5\u7528\u6700\u76F4\u767D\u3001\u6700\u4E0D\u7ED5\u5F2F\u5B50\u3001\u6700\u4F53\u8D34\u3001\u6700\u7B26\u5408\u4F60\u60C5\u611F\u9884\u671F\u7684\u65B9\u5F0F\u544A\u8BC9\u4F60\u2014\u2014\u6B7B\u5FC3\u5427\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u5509\u2026\u2026\u4E0D\u8FC7\uFF0C\u8D77\u7801\u6211\u4EEC\u7EC8\u4E8E\u4E0D\u7528\u98D8\u7740\uFF0C\u80FD\u5728\u8FD9\u7A7A\u95F4\u7AD9\u5148\u6B47\u6B47\u811A\uFF0C\u518D\u60F3\u4E0B\u4E00\u6B65\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u5443\u2026\u2026\u63D0\u9192\u4F60\u4E00\u4E0B\uFF0C\u6BD4\u8D77\u8BF4\u662F\u6211\u4EEC\"\u627E\u5230\"\u5B83\uFF0C\u66F4\u50CF\u662F\u5B83\"\u627E\u5230\"\u6211\u4EEC\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u4EEC\u811A\u4E0B\u7684\u9489\u978B\u73B0\u5728\u88AB\u8FD9\u5E73\u53F0\u5438\u9644\uFF0C\u8DF3\u90FD\u8DF3\u4E0D\u8D77\u6765\u2026\u2026\u5C31\u7B97\u957F\u4E86\u4E09\u5BF9\u9E21\u7FC5\u4E5F\u98DE\u4E0D\u8D77\u6765\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u6211\u8BB0\u5F97\u5F53\u65F6\u4E70\u8FD9\u88C5\u5907\u7684\u65F6\u5019\uFF0C\u5E97\u5458\u8BF4\u5B83\u80FD\u7D27\u7D27\u5438\u9644\u5728\u6240\u6709\u7684\u661F\u4F53\u548C\u5E73\u53F0\u4E0A\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u7136\u540E\uFF0C\u5982\u679C\u60F3\u89E3\u9664\u5438\u9644\u7684\u8BDD\uFF0C\u53EA\u9700\u8981\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: 
    text: "\u6309\u4F4F\u3010Lshift/Enter\u3011\u8131\u79BB\u5BF9\u7A7A\u95F4\u7AD9\u7684\u5438\u9644\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 0
  onComplete:
    m_PersistentCalls:
      m_Calls: []
