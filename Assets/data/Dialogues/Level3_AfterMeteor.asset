  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u4EC0\u4E48\u60C5\u51B5\uFF1F\uFF01"
    portrait: {fileID: 0}
    bigPortrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u73B0\u5728\u6211\u4EEC\u90FD\u770B\u5230\u4E86\u2026\u2026\u51E0\u5341\u5E74\u8FC7\u53BB\u4E86\uFF0C\u9644\u8FD1\u661F\u4F53\u7684\u8F68\u9053\u8FD8\u662F\u4E0D\u7A33\u5B9A\u3002\u6050\u6015\u2026\u2026\u6211\u4EEC\u53C8\u8981\u9047\u5230\u9668\u77F3\u96E8\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: "\u62C9\u5179"
    text: "\u8D77\u7801\u524D\u9762\u8FD9\u51E0\u9897\u6211\u4EEC\u8FD8\u53EF\u4EE5\u8EB2\u4E00\u8EB2\u2026\u2026\u65B9\u6CE2\uFF0C\u4E00\u65E6\u88AB\u7838\u5230\u6211\u4EEC\u5F88\u53EF\u80FD\u4F1A\u76F4\u63A5\u88AB\u5F39\u98DE\uFF0C\u504F\u79BB\u8FD9\u91CC\u5C0F\u884C\u661F\u7684\u91CD\u529B\u3002\u5230\u65F6\u5019\u5C31\u5F88\u96BE\u518D\u56DE\u6765\u6536\u96C6\u4E1C\u897F\u4E86\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 0
  - speakerName: "\u65B9\u6CE2"
    text: "\u88AB\u9668\u77F3\u649E\u98DE\u4E86\uFF0C\u5E94\u8BE5\u518D\u4E5F\u4E0D\u7528\u8003\u8651\u6536\u96C6\u96F6\u4EF6\u7684\u4E8B\u60C5\u4E86\u5427\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u5C0F\u5FC3\u4E3A\u4E0A\uFF0C\u907F\u7740\u8D70\u5427\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
