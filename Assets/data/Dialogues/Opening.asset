  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Opening
  m_EditorClassIdentifier: 
  lines:
  - speakerName: 
    text: "20xx\u5E74\uFF0C\u5DE8\u884C\u661F\u7684\u8F68\u9053\u518D\u6B21\u53D1\u751F\u8FC1\u79FB\uFF0C\u5E26\u6765\u4E86\u4E00\u573A\u8F70\u8F70\u70C8\u70C8\u7684\u7531\u5F57\u661F\u548C\u5C0F\u884C\u661F\u788E\u7247\u7EC4\u6210\u7684\u9668\u77F3\u96E8\u3002"
    portrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u5927\u91CF\u3001\u5FEB\u901F\u7684\u9668\u77F3\u649E\u51FB\u5BF9\u5730\u7403\u662F\u6BC1\u706D\u6027\u7684\u3002\u4EBA\u7C7B\u4FBF\u653E\u5F03\u4E86\u5DF2\u7ECF\u88AB\u9668\u77F3\u6467\u6BC1\u7684\u5730\u7403\uFF0C\u4E5F\u9057\u5F03\u4E86\u73AF\u7ED5\u5728\u5730\u7403\u9644\u8FD1\u7684\u8D44\u4EA7\u3002"
    portrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u5E9F\u5F03\u7684\u7A7A\u95F4\u7AD9\u3001\u4EBA\u9020\u536B\u661F\u3001\u5947\u5F62\u602A\u72B6\u7684\u98DE\u8239\u2026\u2026\u4EBA\u7C7B\u7684\u63A2\u7A76\u5438\u5F15\u4E86\u4E00\u5927\u6279\u5B87\u5B99\u63A2\u9669\u5BB6\u524D\u6765\u63A2\u9669\u3001\u6536\u96C6\u8D44\u6599\uFF0C\u6709\u4E9B\u661F\u7403\u751A\u81F3\u79F0\u5176\u4E3A\u300C\u4F1F\u5927\u7684\u6587\u660E\u590D\u5174\u8BA1\u5212\u300D\u2026\u2026"
    portrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u2026\u2026\u53EA\u4E0D\u8FC7\uFF0C\u4F1F\u5927\u7684\u63A2\u7D22\u603B\u662F\u4F34\u968F\u7740\u4E00\u5B9A\u7684\u98CE\u9669\u2026\u2026"
    portrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: 
    text: "\u6BD4\u5982\u4E24\u4E2A\u88AB\u667E\u5728\u592A\u7A7A\u91CC\u7684\u5012\u9709\u86CB\u2026"
    portrait: {fileID: 0}
    isLeftSide: 0
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 1
  onComplete:
    m_PersistentCalls:
      m_Calls: []
