  lines:
  - speakerName: "\u62C9\u5179"
    text: "\u770B\u6765\u3002\u9668\u77F3\u7834\u574F\u7684\u8FD9\u6240\u7A7A\u95F4\u7AD9\u6CC4\u9732\u4E86\u5F88\u591A\u7684\u80FD\u91CF\u2026\u2026\u6216\u8BB8\u53EA\u8981\u9760\u8FD1\u5B83\u4EEC\uFF0C\u80CC\u5305\u7684\u80FD\u91CF\u5C31\u4F1A\u88AB\u8865\u5145\u3002"
