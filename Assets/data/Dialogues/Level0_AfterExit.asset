    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u53C8\u4E00\u4E2A\u597D\u6D88\u606F\uFF0C\u771F\u4E0D\u9519\uFF0C\u770B\u6765\u6211\u4EEC\u8D70\u4E86\"\u72D7\"\u5C4E\u8FD0\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u5207\u2026\u2026\u4E00\u70B9\u4E5F\u4E0D\u597D\u7B11\u3002"
