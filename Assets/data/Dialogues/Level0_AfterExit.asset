    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: 
    text: "\u8BD5\u7740\u9760\u8FD1\u524D\u65B9\u7684\u80FD\u91CF\u5149\u70B9\uFF0C\u5E76\u8865\u5145\u80CC\u5305\u7684\u80FD\u91CF\u5427\uFF01"
