  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level5_AfterMeteor
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u9668\u77F3\u8D8A\u6765\u8D8A\u5BC6\u96C6\u4E86\u2026\u2026\u4E4B\u524D\u5730\u7403\u5C31\u662F\u88AB\u8FD9\u79CD\u89C4\u6A21\u7684\u9668\u77F3\u6BC1\u706D\u7684\u5417\uFF1F"
    portrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u53EF\u80FD\u8981\u6BD4\u8FD9\u5927\u5F97\u591A\u5F97\u591A\u5427\u3002\u65B9\u6CE2\uFF0C\u90A3\u8FB9\u7684\u661F\u7403\u5DF2\u7ECF\u56DB\u5206\u4E94\u88C2\u4E86\u3002\u4E0D\u8981\u8D70\u90A3\u8FB9\u3002"
    portrait: {fileID: 0}
    isLeftSide: 0
  - speakerName: "\u65B9\u6CE2"
    text: "\u5509\uFF0C\u6211\u4EEC\u811A\u4E0B\u7684\u661F\u7403\u4E5F\u53EF\u80FD\u4F1A\u88AB\u8FD9\u6837\u7684\u9668\u77F3\u7838\u788E\u2026\u2026\u6216\u8BB8\uFF0C\u62C9\u5179\uFF0C\u6211\u4EEC\u7684\u6BCD\u661F\u4E5F\u6709\u4E00\u5929\u4F1A\u7184\u706D\u2026\u2026"
    portrait: {fileID: 0}
    isLeftSide: 1
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u4EEC\u65E0\u6CD5\u963B\u6B62\u5B87\u5B99\u8D70\u5411\u70ED\u5BC2\uFF0C\u4F46\u8D77\u7801\u6211\u4EEC\u53EF\u4EE5\u5148\u4FEE\u597D\u9762\u524D\u7684\u98DE\u8239\u3002\u522B\u8FD9\u4E48\u60B2\u89C2\uFF0C\u80DC\u5229\u5C31\u5728\u773C\u524D\u4E86\u3002"
    portrait: {fileID: 0}
    isLeftSide: 0
  useTypingEffect: 1
  useAnimation: 0
