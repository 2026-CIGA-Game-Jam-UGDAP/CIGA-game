  m_Script: {fileID: 11500000, guid: c0c70052bc13ae44f83abca1f1328c1a, type: 3}
  m_Name: Level0_AfterAttach
  m_EditorClassIdentifier: 
  lines:
  - speakerName: "\u65B9\u6CE2"
    text: "\u6CA1\u9519\uFF01\u4F46\u2026\u2026\u5982\u679C\u4E4B\u540E\u8981\u79BB\u5F00\u8FD9\u91CC\uFF0C\u6211\u4EEC\u8FD8\u9700\u8981\u4E00\u4E2A\u80FD\u628A\u6211\u4EEC\u5F80\u524D\u63A8\u7684\u5DE5\u5177\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6BD4\u5982\u2026\u2026\u4E00\u4E2A\u55B7\u6C14\u80CC\u5305\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u2026\u2026\u4EC0\u4E48\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u6211\u521A\u521A\u5BF9\u8FD9\u91CC\u505A\u4E86\u4E00\u4E0B\u7B80\u5355\u7684\u4FA6\u67E5\uFF0C\u5728\u5730\u4E0B\u53D1\u73B0\u4E86\u4E24\u4E2A\u5907\u7528\u7684\u3001\u5168\u65B0\u7684\u55B7\u6C14\u80CC\u5305\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u8FD9\u5E94\u8BE5\u662F\u4EBA\u7C7B\u7559\u4E0B\u7684\uFF0C\u8D77\u7801\u6709\u4E86\u8FD9\u4E2A\u6211\u4EEC\u884C\u52A8\u8D77\u6765\u5C31\u65B9\u4FBF\u591A\u4E86\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u81F3\u4E8E\u5B83\u7684\u7528\u6CD5\u2026\u2026\u770B\u89C1\u5899\u4E0A\u8FD9\u4E9B\u56FE\u6848\u4E86\u5417\uFF1F\u6211\u731C\u5B83\u662F\u64CD\u4F5C\u624B\u518C\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u6240\u4EE5\u6211\u4EEC\u8981\u5148\u6309\u8FD9\u4E9B\u952E\uFF0C\u7136\u540E\u5C31\u80FD\u98DE\u8D77\u6765\u2026\u2026"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u62C9\u5179"
    text: "\u4E0D\u8FC7\u4F3C\u4E4E\u8981\u5148\u4FDD\u8BC1\u6211\u4EEC\u6CA1\u6709\u5438\u9644\u5728\u5E73\u53F0\u4E0A\uFF0C\u5426\u5219\u80CC\u5305\u4E0D\u4F1A\u8D77\u4F5C\u7528\u3002"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -391726316, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  - speakerName: "\u65B9\u6CE2"
    text: "\u4F60\u8FD8\u8BB0\u5F97\u600E\u4E48\u505A\u662F\u53D6\u6D88\u5438\u9644\u5427\uFF1F"
    portrait: {fileID: 0}
    bigPortrait: {fileID: -1828046989, guid: dcb5a4ef03042bf408b1c650d671b958, type: 3}
  useTypingEffect: 1
  useAnimation: 0
  needsCG: 0
  onComplete:
    m_PersistentCalls:
      m_Calls: []
